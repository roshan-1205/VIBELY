# Test environment configuration
DATABASE_URL=sqlite+aiosqlite:///./vibely_test.db
DATABASE_URL_SYNC=sqlite:///./vibely_test.db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=test-super-secret-key-for-development-only-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
HUGGINGFACE_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
RATE_LIMIT_PER_MINUTE=60