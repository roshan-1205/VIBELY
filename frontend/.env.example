# API Configuration
VITE_API_URL=http://localhost:8000/api/v1
VITE_SOCKET_URL=ws://localhost:8000

# App Configuration
VITE_APP_NAME=Vibely
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false
VITE_ENABLE_WEBSOCKETS=true

# External Services
VITE_SENTRY_DSN=
VITE_ANALYTICS_ID=

# Development
VITE_LOG_LEVEL=info

# Feature Flag Overrides (optional)
# VITE_FEATURE_ENABLEREALTIME=true
# VITE_FEATURE_ENABLENEWFEEDUI=true
# VITE_FEATURE_ENABLEVIBESYNC=true
# VITE_FEATURE_ENABLENOTIFICATIONS=true
# VITE_FEATURE_ENABLEAIRECOMMENDATIONS=false
# VITE_FEATURE_ENABLEADVANCEDSEARCH=false
# VITE_FEATURE_ENABLEDARKMODE=true
# VITE_FEATURE_ENABLEBETAFEATURES=false